CREATE TABLE IF NOT EXISTS PodcastSettings (
    podcastId          TEXT NOT NULL PRIMARY KEY,
    playbackSpeed      REAL,
    notificationsMuted INTEGER NOT NULL DEFAULT 0,
    autoDownload       TEXT NOT NULL DEFAULT 'global',
    skipIntroDurationS INTEGER NOT NULL DEFAULT 0,
    skipOutroDurationS INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY (podcastId) REFERENCES Podcasts(id) ON DELETE CASCADE
);
